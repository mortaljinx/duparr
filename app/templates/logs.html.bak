<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Duparr — Logs</title>
    <link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #000000;
            --surface: #000000;
            --border: #FFFFFF;
            --border-bright: #FFFF00;
            --text: #FFFFFF;
            --muted: #00FFFF;
            --accent: #FFFF00;
            --danger: #FF0000;
            --warn: #FF00FF;
            --ok: #00FF00;
            --info: #0000FF;
            --font-mono: 'VT323', monospace;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-mono);
            font-size: 20px;
            line-height: 1.2;
            min-height: 100vh;
            text-transform: uppercase;
        }

        pre, .log-content { text-transform: none; }

        header {
            background: var(--surface);
            border-bottom: 4px solid var(--border-bright);
            padding: 15px 20px;
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo { font-size: 32px; font-weight: normal; color: var(--accent); letter-spacing: 2px; }
        .logo span { color: var(--muted); font-size: 20px; margin-left: 10px; }

        nav { display: flex; gap: 10px; flex-wrap: wrap; }
        nav a {
            font-size: 20px;
            padding: 4px 10px;
            border: 2px solid var(--border);
            color: var(--text);
            text-decoration: none;
            background: var(--bg);
        }
        nav a::before { content: "[ "; color: var(--muted); }
        nav a::after  { content: " ]"; color: var(--muted); }
        nav a:hover, nav a.active { background: var(--border-bright); color: var(--bg); border-color: var(--border-bright); }
        nav a:hover::before, nav a.active::before,
        nav a:hover::after,  nav a.active::after  { color: var(--bg); }

        .toolbar {
            background: var(--surface);
            border-bottom: 2px dashed var(--border);
            padding: 12px 20px;
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        .btn {
            font-family: var(--font-mono);
            font-size: 20px;
            padding: 4px 12px;
            border: 2px solid var(--border);
            background: var(--bg);
            color: var(--text);
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }
        .btn:hover { background: var(--border-bright); color: var(--bg); border-color: var(--border-bright); }

        .info { color: var(--muted); font-size: 18px; margin-left: auto; }

        .log-content {
            padding: 20px;
            white-space: pre-wrap;
            word-break: break-all;
            line-height: 1.6;
            font-size: 16px;
            color: var(--ok);
        }

        .empty {
            text-align: center;
            padding: 80px 20px;
            color: var(--muted);
            border: 4px dashed var(--muted);
            margin: 20px;
        }
        .empty h2 { font-size: 28px; color: var(--text); margin-bottom: 15px; }

        @media (max-width: 600px) {
            .info { margin-left: 0; }
            .toolbar { flex-direction: column; align-items: stretch; }
            .btn { text-align: center; }
        }
    </style>
</head>
<body>

<header>
    <div class="logo">DUPARR <span>[ DUPLICATE MANAGER ]</span></div>
    <nav>
        <a href="/">DASHBOARD</a>
        <a href="/report">REPORT</a>
        <a href="/undo">UNDO</a>
        <a href="/logs" class="active">LOGS</a>
    </nav>
</header>

<div class="toolbar">
    <a href="/logs" class="btn">↻ REFRESH</a>
    {% if line_count %}
    <span class="info">LAST {{ line_count }} LINES — /DATA/DUPARR.LOG</span>
    {% endif %}
</div>

{% if content %}
<pre class="log-content">{{ content }}</pre>
{% else %}
<div class="empty">
    <h2>[ NO LOG FILE ]</h2>
    <p>Run a scan first to generate log output.</p>
</div>
{% endif %}

</body>
</html>
